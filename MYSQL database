 CREATE TABLE Buses (
         BusID INT PRIMARY KEY AUTO_INCREMENT,
         BusNumber VARCHAR(20),
         Source VARCHAR(100),
         Destination VARCHAR(100),
         DepartureTime DATETIME,
         TotalSeats INT
     );

