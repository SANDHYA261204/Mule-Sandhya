 SELECT Buses.BusNumber, Bookings.SeatNumber, Bookings.BookingDate, Bookings.Status, Payments.PaymentMethod
     FROM Bookings
     JOIN Buses ON Bookings.BusID = Buses.BusID
     Left JOIN Payments on Bookings.BookingID = Payments.BookingID
     WHERE Bookings.UserID = 1;

CREATE VIEW SimpleBookingView AS
     SELECT
         b.BookingID,
         b.UserID,
         bs.BusNumber,
         b.SeatNumber,
         b.BookingDate,
         b.Status
     FROM Bookings b
     JOIN Buses bs ON b.BusID = bs.BusID;
