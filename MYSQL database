 CREATE TABLE Bookings (
         BookingID INT PRIMARY KEY AUTO_INCREMENT,
         UserID INT,
         BusID INT,
         SeatNumber INT,
         BookingDate DATETIME,
         Status VARCHAR(50),
         FOREIGN KEY (UserID) REFERENCES Users(UserID),
         FOREIGN KEY (BusID) REFERENCES Buses(BusID)
     );

