CREATE TABLE Payments (
         PaymentID INT PRIMARY KEY AUTO_INCREMENT,
         BookingID INT,
         Amount DECIMAL(8,2),
         PaymentDate DATETIME,
         PaymentMethod VARCHAR(100),
         FOREIGN KEY (BookingID) REFERENCES Bookings(BookingID)
     );

